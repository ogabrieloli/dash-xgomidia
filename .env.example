# ════════════════════════════════════════════════════
# XGO Midia Platform — Variáveis de Ambiente
# ATENÇÃO: NUNCA commitar valores reais. Copie para .env
# ════════════════════════════════════════════════════

# ─── App ───────────────────────────────────────────��─
NODE_ENV=development
LOG_LEVEL=info

# ─── API ─────────────────────────────────────────────
PORT=3001
HOST=0.0.0.0
PUBLIC_URL=https://app.xgomidia.com.br
INTERNAL_URL=http://api:3001
CORS_ORIGIN=http://localhost:3000
COOKIE_SECRET=troque-por-valor-gerado-com-openssl-rand-base64-32

# ─── Frontend ────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001

# ─── Banco de Dados ──────────────────────────────────
DATABASE_URL=postgresql://xgo:xgo_dev_password@localhost:5432/xgo_platform

# ─── Redis ───────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ─────────────────────────────────────────────
# Gerar com: openssl rand -base64 64
JWT_SECRET=troque-por-valor-gerado-com-openssl-rand-base64-64
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ─── HashiCorp Vault ─────────────────────────────────
# ATENÇÃO: em produção usar AppRole, nunca root token
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=root
VAULT_MOUNT=secret

# ─── Object Storage (Cloudflare R2) ──────────────────
# Obter em: https://dash.cloudflare.com -> R2 -> Manage API tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=xgo-reports

# ─── IA (Anthropic) ──────────────────────────────────
# ATENÇÃO: chave sensível — nunca logar nem expor via API
ANTHROPIC_API_KEY=sk-ant-...

# ─── E-mail (Resend) ─────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=relatorios@xgomidia.com.br

# ─── Meta Ads OAuth ──────────────────────────────────
# ATENÇÃO: tokens de CLIENTE nunca ficam aqui — usar Vault
# Apenas credenciais do APP da Meta (não de clientes)
META_APP_ID=
META_APP_SECRET=
META_API_VERSION=v20.0
# URL de callback cadastrada no painel do Meta App
META_REDIRECT_URI=http://localhost:3001/auth/meta/callback
# URL do frontend para redirecionamentos pós-OAuth
FRONTEND_URL=http://localhost:3000

# ─── Workers — Usuário Sistema ───────────────────────
# ID do usuário criado pelo seed para entradas automáticas de timeline (alerts, etc.)
SYSTEM_USER_ID=

# ─── Google Ads OAuth (Fase 3) ───────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_DEVELOPER_TOKEN=

# ─── Monitoramento ───────────────────────────────────
SENTRY_DSN=
